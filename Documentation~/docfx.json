{
  "metadata": [],
  "build": {
    "globalMetadata": {
      "_appTitle": "景観まちづくり支援ツール",
      "_enableSearch": true
    },
    "content": [
      {
        "files": ["toc.yml", "index.md"]
      },
      {
        "src": "manual",
        "files": ["toc.yml", "*.md"],
        "dest": "manual"
      }
    ],
    "resource": [
      {
        "files": ["resources/**/*"]
      }
    ],
    "sitemap": {
      "changefreq": "yearly"
    },
    "xref": ["https://normanderwan.github.io/UnityXrefMaps/xrefmap.yml"],
    "xrefService": ["https://xref.docs.microsoft.com/query?uid={uid}"],
    "dest": "../.docs/_site"
  }
}
